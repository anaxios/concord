    local consonants=( b c d f g h j k l m n p q r s t v w x y z);
    local rejects=( yy xy qx xq pq wq )
    local result

    while ((${#result} < 4)); do
        local rndc rndv rndcc tmp
        if [[ $(($RANDOM % 2)) == 0 ]]; then
            rndc=$(($RANDOM % ${#consonants[@]}))
            rndv=$(($RANDOM % ${#vowels[@]}))
            tmp="${consonants[rndc]}${vowels[rndv]}"
        fi
        if [[ $(($RANDOM % 2)) == 0 ]]; then
            rndc=$(($RANDOM % ${#consonants[@]}))
            rndcc=$(($RANDOM % ${#consonants[@]}))
            rndv=$(($RANDOM % ${#vowels[@]}))
            tmp="${consonants[rndc]}${vowels[rndv]}${consonants[rndcc]}"
        fi
        if [[ $(($RANDOM % 2)) == 0 ]]; then
            rndc=$(($RANDOM % ${#consonants[@]}))
            rndcc=$(($RANDOM % ${#consonants[@]}))
            rndv=$(($RANDOM % ${#vowels[@]}))
            tmp="${vowels[rndv]}${consonants[rndcc]}"
        fi
        #if [[ "${rejects[*]}" =~ "$tmp" ]]; then
