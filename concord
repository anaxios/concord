#!/usr/bin/env bash
set -e

trap cleanup SIGINT EXIT
#trap handle_resize SIGWINCH

ROWS=$(tput lines)
COLS=$(tput cols)
CONTENT_ROWS=$((ROWS - 1))
OLD_STTY=$(stty -g)
LEAVE=1
SERVER='https://ntfy.daedalist.net/'

cleanup() {
    #wait
    if [[ $LEAVE < 1 ]]; then
        # leave message
        send_msg "$key" "${username}: has left"
    fi
    LEAVE=$((LEAVE - 1))

    printf "\033[r"      # reset scroll region
    tput rmcup           # restore original screen
    stty "$OLD_STTY"

    #echo "cleanup" $nfty_listen_PID
    if kill -0 $CURL_PID 2>/dev/null; then
        #echo "cleanup" "$CURL_PID"
        kill ${CURL_PID}
    fi
    exit
}

preflight() {
    #local requires=( curl )
    if ! [[ "$BASH_VERSION" =~ ^5.+ ]]; then
        echo "Needs a newer version of Bash"
        exit 1
    fi
}

random_name() {
    local vowels=( a e i o u y );
    local consonants=( b c d f g h j k l m n p q r s t v w x y z);
    local result=

    while ((${#result} < 4)); do

        #local limit=5
        #for ((i = 0; i < limit; ++i)); do
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${consonants[rndc]}${vowels[rndv]}"
                result="$result$tmp"
            fi
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndcc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${consonants[rndc]}${vowels[rndv]}${consonants[rndcc]}"
                result="$result$tmp"
            fi
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndcc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${vowels[rndv]}${consonants[rndcc]}"
                result="$result$tmp"
            fi
        #done
    done

    echo "$result"
}

encrypt_msg() {
    local key="$1"; shift
    local msg="$1"
    #echo "$msg" | openssl enc -aes-256-cbc -pbkdf2 -base64 -nosalt -k "$key"
    echo "$msg" | gpg --passphrase "$key" --batch --yes --symmetric -a
}

decrypt_msg() {
    local key="$1"; shift
    local msg="$@"
        #echo "$msg" #| openssl enc -d -aes-256-cbc -pbkdf2 -base64 -nosalt -k "$key"
        gpg --decrypt --passphrase "$key" --batch --yes --quiet <<< "$msg"
}

MESSAGE_BUFFER_OFFSET=0
SCROLLBACK_OFFSET=0
MESSAGE_BUFFER=()
draw_messages() {
    local read_fd="$1"; shift
    local msg

    #MESSAGE_BUFFER_OFFSET=$((${#MESSAGE_BUFFER[@]} - $CONTENT_ROWS))
    #MESSAGE_BUFFER_OFFSET=${#MESSAGE_BUFFER[@]}
    while IFS= read -r -u $read_fd msg; do
        local MESSAGE_BUFFER_LEN=${#MESSAGE_BUFFER[@]}
        MESSAGE_BUFFER_OFFSET=$(max 0 $(( $MESSAGE_BUFFER_LEN - $CONTENT_ROWS + 1)))
        #tput cup $((LINES - 2)) 0
        if [[ -n "$msg" ]]; then
            MESSAGE_BUFFER+=( "$msg" )
            tput sc
            tput civis
            for ((i = 0; i < CONTENT_ROWS; ++i)); do
                tput cup $(($i))  0
                printf "\033[2K"  # clear the line
                echo -n "${MESSAGE_BUFFER[MESSAGE_BUFFER_OFFSET + i]}"
                #echo -n "${MESSAGE_BUFFER_LEN}"
            done
            tput rc
            #tput cr
            tput cup $((LINES - 1)) 2
            tput cnorm
        fi
    done
}

send_msg() {
    local key="$1"; shift
    echo "$@" | curl -s -d @- "${SERVER}/${key}" >/dev/null
}

