#!/usr/bin/env bash
set -e

trap cleanup SIGINT EXIT SIGKILL

cleanup() {
    printf "\e[r"
    tput cup $((LINES )) 0
    exit
}

encrypt_msg() {
    local key="$1"; shift
    local msg="$1"
    #echo "$msg" | openssl enc -aes-256-cbc -pbkdf2 -base64 -nosalt -k "$key"
    echo "$msg" | gpg --passphrase "$key" --batch --yes --symmetric -a
    echo '^'
}

decrypt_msg() {
    local key="$1"; shift
    local msg
    while IFS= read -r -d '^' msg; do
        #echo "$msg" #| openssl enc -d -aes-256-cbc -pbkdf2 -base64 -nosalt -k "$key"
        gpg --decrypt --passphrase "$key" --batch --yes --quiet <<< "$msg"
        echo
    done
}

show_msg() {
    local read_fd="$1"; shift
    local msg
    while read -r -u $read_fd msg; do
        tput cup $((LINES - 2)) 0
        echo "$msg"
        tput cup $((LINES - 1)) 0
    done
}

random_name() {
    local vowels=( a e i o u y );
    local consonants=( b c d f g h j k l m n p q r s t v w x y z);
    local result=

    while ((${#result} == 0)); do

        #local limit=5
        #for ((i = 0; i < limit; ++i)); do
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${consonants[rndc]}${vowels[rndv]}"
                result="$result$tmp"
            fi
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndcc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${consonants[rndc]}${vowels[rndv]}${consonants[rndcc]}"
                result="$result$tmp"
            fi
            if [[ $(($RANDOM % 2)) == 0 ]]; then
                local rndc=$(($RANDOM % ${#consonants[@]}))
                local rndcc=$(($RANDOM % ${#consonants[@]}))
                local rndv=$(($RANDOM % ${#vowels[@]}))
                local tmp="${vowels[rndv]}${consonants[rndcc]}"
                result="$result$tmp"
            fi
        #done
    done

    echo "$result"
}

preflight() {
    local requires=( gpg jqi curl)
}

main() {
    local username="${1}"
    local key="${2:-0xDEADBEA7}"
    if [[ -z $username ]]; then
        username="$(random_name)"
    fi
    LINES=$(tput lines)
    COLS=$(tput cols)

    preflight

    printf "\e[1;$((LINES -1))r"
    tput cup $((LINES - 2)) 0
    echo
    tput cup $((LINES )) 0

    coproc decrypt_msg "$key"
    exec {READ_FD}<&${COPROC[0]}-
    show_msg $READ_FD &

    local usr_input
    while read -re usr_input; do
        #tput sc
        #tput cuu1
        tput dl1
        #tput cuu1
        #tput el
        #tput rc
        encrypt_msg "$key" "${username}: $usr_input" >&"${COPROC[1]}"
    done
}; main "$@"
