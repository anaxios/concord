handle_resize() {
    ROWS=$(tput lines)
    COLS=$(tput cols)
    CONTENT_ROWS=$((ROWS - 1))
    tput smcup
    tput clear
    printf "\033[1;${CONTENT_ROWS}r"  # reset scroll region
    #draw_input "$usr_input"
}

max() {
    local x=$1; shift
    local y=$1
    if [[ $x -lt $y ]]; then
        echo $y
    else
        echo $x
    fi
}

draw_input() {
    IFS=
    local text="$1"
    local pos="${2:-${#text}}"
    local cols=$(($COLS - 3))
    tput cup $((ROWS - 1)) 0
    printf "\033[2K"  # clear the line
    #if [[ $pos -ge $cols ]]; then
        local min=$(max 0 $(($pos - $cols)))
        printf "> %s" "${text:$min:$cols}"
        tput cup $((ROWS - 1)) $((pos + 2))
    #else
    #    printf "> %s" "$text"
    #    tput cup $((ROWS - 1)) $((pos + 2))
    #fi
}

main() {
    username="${1}"
    key="${2:-0xDEADBEA7}"
    if [[ -z $username ]]; then
        username="$(random_name)"
    fi

    preflight

    tput smcup
    tput clear
    #printf "\033[1;${CONTENT_ROWS}r"

    echo "To exit use CTRL+c"

    coproc ntfy_listen ( curl -s --no-buffer -N "${SERVER}/${key}/raw?since=720m" )
    #coproc ntfy_listen ( cat )
    CURL_PID=$ntfy_listen_PID
    exec {READ_FD}<&${ntfy_listen[0]}
    draw_messages $READ_FD &

    ## arrival message
    send_msg "$key" "${username}: has arrived"

    local usr_input=( )
    local cur_pos=0
    local char
    local esc
    draw_input
    while IFS= read -r -s -n1 char; do
        if [[ -z "$char" ]]; then
            if [[ -n "${#usr_input[@]}" ]]; then
                send_msg "$key" "${username}: ${usr_input[*]}"
                #echo "$key" "${username}: ${usr_input[*]}" >&${ntfy_listen[1]}
                cur_pos=0
                usr_input=()
            fi
        elif [[ $char == $'\177' ]]; then  # backspace
            local usr_input_len=${#usr_input[@]}
            (( cur_pos == 0 )) && continue || true
            (( cur_pos > 0 )) && (( cur_pos-- )) || true
            for ((i = cur_pos; i <= usr_input_len; ++i )); do
                usr_input[i]="${usr_input[i+1]}"
            done
            unset usr_input[usr_input_len - 1]
            usr_input=( ${usr_input[@]} )
        elif [[ $char == $'\033' ]]; then # escape sequences
            #cur_pos=${#usr_input}
            read -r -s -n5 -t 0.05 esc || true  # consume up to 5 more bytes
            case "$esc" in
                '[D')  # left arrow
                    (( cur_pos > 0 )) && (( cur_pos-- )) || true
                    ;;
                '[C')  # right arrow
                    (( cur_pos < ${#usr_input[@]} )) && (( cur_pos++ )) || true
                        ;;
                    *)  # discard other sequences
                        ;;
                esac
            #draw_input "$usr_input"
            #draw_input "$usr_input" "$cur_pos"
            #continue
        else
            #copy forward
            usr_input_len=${#usr_input[@]}
            for ((i = usr_input_len - 1; i >= cur_pos; --i )); do
                usr_input[i+1]="${usr_input[i]}"
            done
            usr_input[cur_pos++]="$char"
        fi
    draw_input "${usr_input[*]}" "$cur_pos"
    done


}; main "$@"
