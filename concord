#!/usr/bin/env bash
#set -e

trap cleanup INT SIGINT EXIT
trap handle_resize SIGWINCH

ROWS=$(tput lines)
COLS=$(tput cols)
SCROLL=0
CONTENT_ROWS=$((ROWS - 1))
OLD_STTY=$(stty -g)
SERVER='https://ntfy.daedalist.net/'

LEAVE=1
cleanup() {
    if [[ $LEAVE < 1 ]]; then
        # leave message
        send_msg "$key" "${username}:" "has left"
    fi
    LEAVE=$((LEAVE - 1))

    tput cnorm
    printf "\033[r"      # reset scroll region
    tput rmcup           # restore original screen
    stty "$OLD_STTY"

    if kill -0 $CURL_PID 2>/dev/null; then
        kill ${CURL_PID}
    fi
    if kill -0 $input_handler_pid 2>/dev/null; then
        kill $input_handler_pid
    fi
    if [[ -p /tmp/EVENT_BUS ]]; then
        rm -f /tmp/EVENT_BUS
    fi
    exit
}

preflight() {
    local requires=( curl )
    if ! [[ "$BASH_VERSION" =~ ^5.+ ]]; then
        echo "Needs a newer version of Bash"
        exit 1
    fi

    for cmd in "${requires[@]}"; do
        if ! command -v "$cmd" >/dev/null; then
            echo "requires $cmd to be installed"
            exit 1
        fi
    done

    if ! [[ -p /tmp/EVENT_BUS ]]; then
        mkfifo /tmp/EVENT_BUS
    fi
}

